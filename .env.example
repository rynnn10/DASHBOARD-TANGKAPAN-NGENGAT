# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL hosting aplikasi ini.
APP_URL="MY_APP_URL"

# VITE_GAS_URL: URL deployment Google Apps Script (kode.gs).
# Cara mendapatkan: Google Apps Script → Deploy → Manage Deployments → salin URL Web App.
# File .env TIDAK boleh di-commit ke Git (sudah ada di .gitignore).
VITE_GAS_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"
