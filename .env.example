# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: URL hosting aplikasi ini.
APP_URL="MY_APP_URL"

# VITE_GAS_URL: URL deployment Google Apps Script (kode.gs).
# Cara mendapatkan: Google Apps Script → Deploy → Manage Deployments → salin URL Web App.
# File .env TIDAK boleh di-commit ke Git (sudah ada di .gitignore).
VITE_GAS_URL="https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec"

# VITE_MQTT_*: broker MQTT (kosongkan untuk pakai broker publik default).
# Untuk HiveMQ Cloud (auth + TLS) — lihat tutorial di README.
VITE_MQTT_URL="wss://YOUR_CLUSTER.s1.eu.hivemq.cloud:8884/mqtt"
VITE_MQTT_USER="YOUR_MQTT_USER"
VITE_MQTT_PASS="YOUR_MQTT_PASS"

# CLASP_DEPLOYMENT_ID: deployment ID Apps Script untuk skrip `npm run gas:deploy`.
# = bagian token pada URL Web App: .../macros/s/<INI>/exec
CLASP_DEPLOYMENT_ID="YOUR_DEPLOYMENT_ID"
